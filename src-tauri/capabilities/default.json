{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "sql:default",
    "shell:default",
    "fs:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "npx",
          "cmd": "npx",
          "args": true
        }
      ]
    },
    {
      "identifier": "fs:allow-read",
      "allow": [
        { "path": "$HOME/.claude/**" },
        { "path": "$HOME/.cursor/**" },
        { "path": "$HOME/.agents/**" },
        { "path": "$HOME/.gemini/**" },
        { "path": "**" }
      ]
    },
    {
      "identifier": "fs:allow-write",
      "allow": [
        { "path": "$HOME/.claude/**" },
        { "path": "$HOME/.cursor/**" },
        { "path": "$HOME/.agents/**" },
        { "path": "$HOME/.gemini/**" },
        { "path": "**" }
      ]
    }
  ]
}
